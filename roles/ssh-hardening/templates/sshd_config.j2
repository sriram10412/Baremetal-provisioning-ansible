# ══════════════════════════════════════════
# Hardened sshd_config
# Generated by Ansible — do not edit manually
# CIS Benchmark Level 2 compliant
# ══════════════════════════════════════════

# ── PORT & PROTOCOL ──
Port {{ ssh_port }}
Protocol 2
AddressFamily inet                     # IPv4 only

# ── HOST KEYS (strong only) ──
HostKey /etc/ssh/ssh_host_ed25519_key
HostKey /etc/ssh/ssh_host_rsa_key

# ── CIPHERS, MACS & KEY EXCHANGE ──
Ciphers {{ ssh_allowed_ciphers | join(',') }}
MACs {{ ssh_allowed_macs | join(',') }}
KexAlgorithms {{ ssh_allowed_kex | join(',') }}

# ── AUTHENTICATION ──
PermitRootLogin {{ ssh_permit_root_login }}
PasswordAuthentication {{ ssh_password_authentication }}
PermitEmptyPasswords {{ ssh_permit_empty_passwords }}
PubkeyAuthentication yes
AuthorizedKeysFile .ssh/authorized_keys
ChallengeResponseAuthentication no
UsePAM {{ ssh_use_pam }}
KerberosAuthentication no
GSSAPIAuthentication no

# ── LOGIN CONTROLS ──
MaxAuthTries {{ ssh_max_auth_tries }}
MaxSessions {{ ssh_max_sessions }}
LoginGraceTime {{ ssh_login_grace_time }}
MaxStartups 10:30:60                   # 10 unauthenticated, 30% drop rate, max 60

# ── SESSION TIMEOUT ──
ClientAliveInterval {{ ssh_client_alive_interval }}
ClientAliveCountMax {{ ssh_client_alive_count_max }}

# ── DISABLE DANGEROUS FEATURES ──
X11Forwarding {{ ssh_x11_forwarding }}
AllowTcpForwarding {{ ssh_allow_tcp_forwarding }}
AllowAgentForwarding {{ ssh_agent_forwarding }}
AllowStreamLocalForwarding no
PermitTunnel no
GatewayPorts no
PermitUserEnvironment no
DebianBanner no

# ── LOGGING ──
SyslogFacility AUTH
LogLevel VERBOSE                       # log fingerprints of keys used

# ── LEGAL BANNER ──
Banner /etc/issue.net

# ── SFTP ──
Subsystem sftp /usr/lib/openssh/sftp-server -l INFO -f AUTH
